# Smoke-fixture Turtle input for `cargo run -p xtask -- verify`.
# See external/fact-oracles/fixtures/smoke/nt/smoke.nt for the
# rationale on coverage. This companion adds `@prefix` + `@base`
# so Turtle-specific canonicalisation is exercised.
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ex:   <http://example.org/> .
@base         <http://example.org/> .

ex:alice foaf:name "Alice" ;
         ex:age  "30"^^<http://www.w3.org/2001/XMLSchema#integer> ;
         ex:knows ex:bob .

ex:bob foaf:name "Bøb Ünïcødé 😀"@en .

_:carol ex:knows ex:alice .
